  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
/>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
	//TESTIMONIAL SLIDER
	 const testimonial = new Swiper('#testimonial', {
  	a11y: {
    containerMessage: 'This is a sample slider',
    containerRoleDescriptionMessage: 'Slider Container',
    nextSlideMessage: 'Button for the next slide',
    prevSlideMessage: 'Button for the previous slide',
    paginationBulletMessage: 'Button to jump to slide {{index}}',
    slideLabelMessage: 'Slide {{index}} of {{slidesLength}}',
    slideRole: 'listitem',
    itemRoleDescriptionMessage: 'Slide group',
  },
  keyboard: true,
  grabCursor: true,
  slidesPerView: 1,
  loop: true,
  createElements: true,
  pagination: {
    el: ".testimonial-pagination",
    clickable: true,
  },
  navigation: {
    nextEl: ".test-button-next",
    prevEl: ".test-button-prev",
  },
  autoplay: true,
  on: {
    init: function () {
      const swiperWrapper = document.querySelector('.swiper-wrapper');
      if (swiperWrapper) {
        swiperWrapper.removeAttribute('role');
        swiperWrapper.setAttribute('role', 'list');
      }

      this.slides.forEach(slide => {
        if (!slide.classList.contains('swiper-slide-active')) {
          slide.setAttribute('aria-hidden', 'true');
        } else {
          slide.removeAttribute('aria-hidden');
        }
      });
    },

    slideChange: function () {
      this.slides.forEach(slide => {
        if (slide.classList.contains('swiper-slide-active')) {
          slide.removeAttribute('aria-hidden');
        } else {
          slide.setAttribute('aria-hidden', 'true');
        }
      });
    }
  }
});
</script></div></section><section class="section about"><div class="container"><div id="w-node-_35f4deaf-3465-32bd-766c-a8b955030249-e5bcab26" class="who-are-we-image-wrapper"><div id="w-node-_9d5b8bca-7a75-36d2-5e5f-c2cd0527f4d2-e5bcab26" class="who-are-we-left-img"></div><div id="w-node-_1dc3f444-288a-0abe-b549-569aac6b6de7-e5bcab26" class="who-are-we-right-img"></div></div><div id="w-node-_5d3ea76a-d5ec-7d93-c947-1faa24f9af4e-e5bcab26" class="who-are-we-text-wrapper"><div id="w-node-c9df4f1c-0eea-af27-8104-61c63c03fdfa-e5bcab26" class="who-are-we-left"><div class="label-wrapper"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062cffc81f0d2b6e7bdb7_Frame%2018.svg" loading="lazy" alt="" class="label-svg"/><div class="label">ABOUT</div><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062ce1a4d33d9fc250b20_Frame%2019.svg" loading="lazy" alt="" class="label-svg"/></div><h2>World of ThreadBeast</h2></div><div id="w-node-dbab0ba2-ac0b-fad5-3a10-c2a4ce3c5941-e5bcab26" class="who-are-we-right"><p class="paragraph-opacity">We’re a diverse team of menswear enthusiasts, tech innovators, and culture experts dedicated to redefining how menswear is approached. We believe in style—and redefining the way it’s curated, delivered, and discussed today.</p></div></div></div></section><section class="section faq"><div class="container grid"><div id="w-node-_9cbb17d5-c970-0d5d-ebc7-33ea083822dd-083822db" class="faq-left-column"><div class="label-wrapper"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062cffc81f0d2b6e7bdb7_Frame%2018.svg" loading="lazy" alt="" class="label-svg"/><div class="label">support</div><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062ce1a4d33d9fc250b20_Frame%2019.svg" loading="lazy" alt="" class="label-svg"/></div><h2>frequently asked questions</h2></div><div id="w-node-_9cbb17d5-c970-0d5d-ebc7-33ea083822e5-083822db" class="faq-right-column"><div class="faq-collection-wrapper w-dyn-list"><div role="list" class="faq-collection-list w-dyn-items"><div role="listitem" class="faq-wrapper w-dyn-item"><div role="button" tabindex="0" class="question-wrapper"><h3 class="heading-style-h4 uppercase max-width-faq">How do I choose what I get?</h3><div class="faq-line-1"></div><div class="faq-line-2"></div></div><div class="faq-text-wrapper"><div class="faq-rich-text w-richtext"><p>When you sign up as a new customer, we collect your style preferences. Each month you’ll have the opportunity to give us additional feedback and preview the clothes we’ve curated for your next box. For each item in the box, we give you the control to swap it for another piece that we think you’ll love. Or, leave it up to our stylists to pick something great for you. We do our best to make sure you love every item in your box!</p></div></div></div><div role="listitem" class="faq-wrapper w-dyn-item"><div role="button" tabindex="0" class="question-wrapper"><h3 class="heading-style-h4 uppercase max-width-faq">Can I exchange or return an item?</h3><div class="faq-line-1"></div><div class="faq-line-2"></div></div><div class="faq-text-wrapper"><div class="faq-rich-text w-richtext"><p>In order to keep our members prices low, we currently do not accept returns. However, if you have 2 or more items that didn’t work out in a single package, we offer a complimentary exchange once every 6 packages. Otherwise, a $20 processing fee is applied to initiate an exchange.<br/><br/>To be eligible for an exchange, you must reach out to us within 30 days from the date you receive your items. In addition, we ask that you provide feedback on the items so we can update your style profile moving forward. Please email us at <a href="mailto:assistant@threadbeast.com">assistant@threadbeast.com</a> to initiate your exchange. You will receive exchange instructions by email.<br/><br/>Please do not return packages without receiving confirmation from our customer service team, as we are unable to refund your shipping charges.</p></div></div></div><div role="listitem" class="faq-wrapper w-dyn-item"><div role="button" tabindex="0" class="question-wrapper"><h3 class="heading-style-h4 uppercase max-width-faq">Can I cancel or change my plan?</h3><div class="faq-line-1"></div><div class="faq-line-2"></div></div><div class="faq-text-wrapper"><div class="faq-rich-text w-richtext"><p>You can upgrade, downgrade, pause, or cancel your plan by logging in to the member portal. You can also email <a href="mailto:assistant@threadbeast.com">assistant@threadbeast.com</a> from the email address you signed up with or call us at (314) 877-8536 to start the process. Please note you are eligible to cancel within 7 days from the date you received your last package. Should you wish to restart your subscription, simply send us an email and we’ll be happy to assist you!</p></div></div></div></div></div><a href="http://help.threadbeast.com/" class="button-link w-inline-block"><div class="button-arrow-wrap"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d07461cc63510c7ba6c73a_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img"/><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d07461cc63510c7ba6c73a_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img-2"/></div><div class="button-text">help center</div></a></div><div class="display-none w-embed w-script"><script>
document.querySelectorAll('.question-wrapper').forEach(question => {
  question.addEventListener('click', () => {
    document.querySelectorAll('.question-wrapper').forEach(item => {
      const isOpen = item.nextElementSibling && item.nextElementSibling.clientHeight > 0;
      
      if (item !== question && isOpen) {
        item.click(); 
      }
    });
  });
});

</script></div><div class="display-none w-embed"><style>
