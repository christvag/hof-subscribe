	function initButtonCharacterStagger() {
  const offsetIncrement = 0.01; // Transition offset increment in seconds
  const buttons = document.querySelectorAll('[data-button-animate-chars]');

  buttons.forEach(button => {
    const text = button.textContent; // Get the button's text content
    button.innerHTML = ''; // Clear the original content

    [...text].forEach((char, index) => {
      const span = document.createElement('span');
      span.textContent = char;
      span.style.transitionDelay = `${index * offsetIncrement}s`;

      // Handle spaces explicitly
      if (char === ' ') {
        span.style.whiteSpace = 'pre'; // Preserve space width
      }

      button.appendChild(span);
    });
  });
}

// Initialize Button Character Stagger Animation
document.addEventListener('DOMContentLoaded', () => {
  initButtonCharacterStagger();
});
</script></div></a></div></div></div></div></div><div class="display-none w-embed w-script"><script>
  const section = document.querySelector("[basic-plan]");
  const planTypes = ["basic", "essential", "premium", "baller"];

  planTypes.forEach(plan => {
    const attrName = `${plan}-plan`;
    const newPriceValue = section.getAttribute(attrName);

    if (newPriceValue) {
      const targetPlanName = plan.charAt(0).toUpperCase() + plan.slice(1); // "basic" → "Basic"

      const cmsItem = document.querySelector(`[cms-name="${targetPlanName}"]`);
      if (!cmsItem) return;

      const oldPrices = cmsItem.querySelectorAll(".price-wrapper h3");
				oldPrices.forEach(price => {
  				price.style.textDecoration = "line-through";
				});

      const newPriceWrapper = cmsItem.querySelector(".new-price-wrapper");
      if (newPriceWrapper) {
        newPriceWrapper.style.display = "flex";
      }

      const newPrice = cmsItem.querySelector(".heading-style-h1.new-price");
      if (newPrice) {
        newPrice.textContent = newPriceValue;
      }
    }
  });

</script></div></section><section class="section testimonials"><div class="container relative"><div id="testimonial" class="swiper testimonials w-node-_1526df26-3823-8c95-73cc-62fb2dbefa9a-2dbefa98 w-dyn-list"><div role="list" class="swiper-wrapper w-dyn-items"><div role="listitem" class="swiper-slide testimonial-slide w-dyn-item"><div class="testimonial-wrapper"><div class="overlay display-none"></div><img src="https://cdn.prod.website-files.com/plugins/Basic/assets/placeholder.60f9b1840c.svg" loading="lazy" alt="" class="testimonial-image"/><div class="testimonial-content"><blockquote>&quot;In love with my new clothes thank you @threadbeast you guys nailed it&quot;</blockquote><div class="testimonial-info"><div class="label">Roy</div><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d15320c361e270b228fe5d_Group%2012151.svg" loading="lazy" alt="" class="testimonial-svg"/><div class="label">Compton, CA</div></div></div></div></div><div role="listitem" class="swiper-slide testimonial-slide w-dyn-item"><div class="testimonial-wrapper"><div class="overlay display-none"></div><img src="https://cdn.prod.website-files.com/plugins/Basic/assets/placeholder.60f9b1840c.svg" loading="lazy" alt="" class="testimonial-image"/><div class="testimonial-content"><blockquote>“First box great apparel for the price can’t wait for my next box from #threadbeast”</blockquote><div class="testimonial-info"><div class="label">Edward </div><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d15320c361e270b228fe5d_Group%2012151.svg" loading="lazy" alt="" class="testimonial-svg"/><div class="label">Tallahassee, FL</div></div></div></div></div><div role="listitem" class="swiper-slide testimonial-slide w-dyn-item"><div class="testimonial-wrapper"><div class="overlay display-none"></div><img src="https://cdn.prod.website-files.com/plugins/Basic/assets/placeholder.60f9b1840c.svg" loading="lazy" alt="" class="testimonial-image"/><div class="testimonial-conten