<style>
/* 1. CONTAINER SETTINGS */
.brand-scroll-list {
  /* Disable standard padding to avoid iOS bug */
  padding-left: 0 !important;
  padding-right: 0 !important;
  
  /* SNAP SETTINGS (Parent) */
  /* This moves the snap target 5% inward so it aligns with your margin */
  scroll-padding-left: 5% !important;
  scroll-padding-right: 5% !important;
  scroll-snap-type: x mandatory;
  
  /* Layout */
  display: flex !important;
  justify-content: flex-start !important;
  overflow-x: auto !important;
  width: 100%;
  gap: 16px;
  
  /* Hide scrollbars */
  -webkit-overflow-scrolling: touch;
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.brand-scroll-list::-webkit-scrollbar {
  display: none;
}

/* 2. THE MISSING PIECE: CHILD SNAP SETTINGS */
.brand-scroll-list .w-dyn-item {
  /* This was missing! It tells the card TO snap */
  scroll-snap-align: start;
  flex-shrink: 0;
}

/* 3. ITEM MARGINS (The "Bleed" Spacers) */
.brand-scroll-list .w-dyn-item:first-child {
  /* Creates the visual space on the left */
  margin-left: 5% !important;
}

.brand-scroll-list .w-dyn-item:last-child {
  /* Creates the visual space on the right */
  margin-right: 5% !important;
}

/* 4. DESKTOP ALIGNMENT (90rem+) */
@media screen and (min-width: 90rem) {
  /* Update Snap Point */
  .brand-scroll-list {
    scroll-padding-left: calc((100vw - 88rem) / 2) !important;
  }
  
  /* Update Visual Margin */
  .brand-scroll-list .w-dyn-item:first-child {
    margin-left: calc((100vw - 88rem) / 2) !important;
  }
}

/* 5. MOBILE WIDTHS */
@media screen and (max-width: 767px) {
  .brand-scroll-list .w-dyn-item {
    width: 75vw;
  }
}
</style>

<style>
.promo-scroll-list {
  display: flex !important;
  flex-wrap: nowrap !important;
  overflow-x: auto !important;
  overflow-y: hidden !important;
  -webkit-overflow-scrolling: touch;
  -ms-overflow-style: none;
  scrollbar-width: none;
  padding-inline-start: 5%;
  padding-inline-end: 5%;
  scroll-snap-type: x mandatory;
  scroll-padding: 0 5%;
  gap: 16px;
}
.promo-scroll-list::-webkit-scrollbar {
  display: none;
}

.promo-card {
  flex-shrink: 0;
  scroll-snap-align: start;
  width: 368px;
  height: 630px;
  position: relative;
  overflow: hidden;
}

.promo-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.promo-card:hover .promo-card-bg {
  transform: scale(1.05);
}

.promo-card-content {
  position: relative;
  z-index: 1;
}

.promo-button {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
  padding: 12px 24px;
  color: white;
  text-transform: uppercase;
  font-size: 14px;
  letter-spacing: 1px;
  transition: all 0.3s ease;
}

.promo-card:hover .promo-button,
.promo-card:hover .promo-button * {
  background: white;
  color: black;
  border-color: white;
}

@media screen and (max-width: 767px) {
  .promo-card {
    width: 85vw;
    height: 630px;
  }
}
</style>


<style>
.promo-banner {
  position: relative;
  height: 300px;
  overflow: hidden;
}

.promo-banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}

.promo-banner-content {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 100%;
  padding: 0 5%;
}

.promo-banner-headline {
  font-size: 3vw;
  font-weight: 900;
  color: white;
  text-transform: uppercase;
  margin: 0;
  font-style: italic;
}

.promo-banner-subtext {
  color: rgba(255, 255, 255, 0.8);
  font-size: 14px;
  margin-top: 8px;
}

.promo-banner-btn {
  background: white;
  color: black;
  padding: 16px 32px;
  font-weight: 600;
  text-transform: uppercase;
  text-decoration: none;
}

.promo-banner-btn:hover {
  background: rgba(255, 255, 255, 0.9);
}

@media screen and (max-width: 767px) {
  .promo-banner {
    height: 250px;
  }
  
  .promo-banner-content {
    flex-direction: column;
    justify-content: center;
    text-align: center;
    gap: 16px;
  }
  
  .promo-banner-headline {
    font-size: 8vw;
  }
}
.promo-banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.3);
  z-index: 0;
}
</style>

<style>
/* 1. BASE STYLES (Mobile, Tablet, Laptop) */
.promo_scroll_track {
  display: flex !important;
  flex-wrap: nowrap !important;
  overflow-x: auto !important;
  overflow-y: hidden !important;
  
  /* Standard Padding for smaller screens */
  padding-left: 5%; 
  padding-right: 5%;
  gap: 16px;
  scroll-padding: 0 1rem;
  
  /* Scroll Physics */
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  
  /* Hide Scrollbars (Firefox/IE) */
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* Hide Scrollbars (Chrome/Safari) */
.promo_scroll_track::-webkit-scrollbar {
  display: none;
}

/* 2. LARGE SCREEN OVERRIDE (Only runs on 1440px+) */
/* This matches the logic from your Brand section screenshot */
@media screen and (min-width: 90rem) {
  .promo_scroll_track {
    padding-left: calc((100vw - 88rem) / 2) !important;
    scroll-padding-left: calc((100vw - 88rem) / 2) !important;
  }
}

/* 3. CARD SETTINGS */
.promo_card_v2, .brand_card_v2 {
  flex-shrink: 0 !important;
  scroll-snap-align: start;
}
</style></head><body><a href="#cms-hero-swiper">Text Link</a><div data-animation="default" class="navigation w-nav" data-easing2="ease" data-easing="ease" data-collapse="medium" data-w-id="ef971416-f16a-30d1-9855-e6f28d67a8d6" role="banner" data-duration="400" data-doc-height="1"><div class="nav-top v1-element"><div class="text-s text-neutral-white font-weight-600">🔥 SIGN UP TODAY: $100 FREE EXTRAS WITH CODE <strong>BONUS100</strong><br/></div></div><div class="nav-container v1-element"><a href="/" aria-current="page" class="nav-brand hide-desktop w-nav-brand w--current"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67dc7e55e7b57e3f8b64dc98_Layer_1%20(2).svg" loading="lazy" alt="ThreadBeast Logo" class="nav-logo"/></a><nav role="navigation" class="nav-menu w-nav-menu"><div class="nav-menu-mask"><a href="/" aria-current="page" class="nav-brand hide-mobile w-nav-brand w--current"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67dc7e55e7b57e3f8b64dc98_Layer_1%20(2).svg" loading="lazy" alt="ThreadBeast Logo" class="nav-logo"/></a><div class="nav-menu-left"><a href="/" aria-current="page" class="nav-link border-top hide-desktop w-nav-link w--current">home</a><a href="/community" class="nav-link w-nav-link">community</a><a href="/how-it-works" class="nav-link w-nav-link">how it works</a><div data-hover="false" data-delay="300" data-w-id="a4043e5f-e958-2fff-eaa1-0d96410bf08c" class="dropdown w-dropdown"><div class="dropdown-toggle w-dropdown-toggle"><div class="dropdown-text">styles</div><div class="nav-plus-wrapper"><div class="nav-line-ver"></div><div class="nav-line-hor"></div></div></div><nav class="dropdown-list w-dropdown-list"><a href="/styles/streetwear" class="dropdown-link w-inline-block"><div>streetwear</div><div class="button-arrow-wrap"><div class="button-link-img w-embed"><svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
