<path fill-rule="evenodd" clip-rule="evenodd" d="M7.45001 15.9344L10.4506 16.0337L17.4853 8.99909L10.5102 2.02405L7.39548 2.11834L10.8497 5.57258C11.6905 6.41335 12.4605 7.16669 13.1612 7.83262L1.94318 7.8856L2.04798 10.2241L13.2658 10.1709C12.5807 10.8208 11.8232 11.5612 10.9931 12.3913L7.45001 15.9344Z" fill="currentColor"/>
</svg></div></div></div><div id="styles-swiper" class="styles-swiper-wrapper w-node-d8528966-75a2-2075-56d7-63b5988dca0b-e5bcab26"><div class="styles-custom-slider-wrapper"><div tabindex="0" class="styles-custom-slide"><div class="slide-bg"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67e28d4cd2bf3844d30ff6c4_Rectangle%2023770%20(7).webp" loading="lazy" alt="Stylish man in a brown t-shirt" class="our-style-bg-image"/><div class="slide-overlay"></div></div><div class="styles-content"><h2 class="jumbo-h text-neutral-white">contemporary</h2><p class="margin-5xl">Contemporary fashion often features minimalist aesthetics, clean lines, and high-quality materials, balancing sophistication with wearability.</p><a href="/styles/contemporary" class="button-link w-inline-block"><div class="button-arrow-wrap"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d00d7bda13bf619651aa6b_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img"/><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d00d7bda13bf619651aa6b_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img-2"/></div><div class="button-text text-neutral-white">link to style</div></a></div></div><div tabindex="0" class="styles-custom-slide"><div class="slide-bg"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67e28cc4a0c27f7cb4ce3fa4_Frame%201321318451%20(2).webp" loading="lazy" alt="Stylish man in a green checked shirt and brown trousers" class="our-style-bg-image"/><div class="slide-overlay"></div></div><div class="styles-content"><h2 class="jumbo-h text-neutral-white">heritage</h2><p class="margin-5xl">Heritage fashion is rooted in tradition, craftsmanship, and timeless design. It often  revolves around brands with a long history, known for their durable, high-quality pieces  inspired by classic workwear, military, or outdoor gear.</p><a href="/styles/heritage" class="button-link w-inline-block"><div class="button-arrow-wrap"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d00d7bda13bf619651aa6b_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img"/><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d00d7bda13bf619651aa6b_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img-2"/></div><div class="button-text text-neutral-white">link to style</div></a></div></div><div tabindex="0" class="styles-custom-slide"><div class="slide-bg"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67e28f39d2bf3844d311f6ce_Rectangle%2023770%20(8).webp" loading="lazy" alt="Stylish man in a checked shirt, denim shorts and white converse shoes" class="our-style-bg-image"/><div class="slide-overlay"></div></div><div class="styles-content"><h2 class="jumbo-h text-neutral-white">streetwear</h2><p class="margin-5xl">An expression of street culture, this style blends durable, loose-fitting silhouettes with bold graphics and statement pieces. Rooted in skate and hip-hop culture.</p><a href="/styles/streetwear" class="button-link w-inline-block"><div class="button-arrow-wrap"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d00d7bda13bf619651aa6b_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img"/><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d00d7bda13bf619651aa6b_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img-2"/></div><div class="button-text text-neutral-white">link to style</div></a></div></div></div></div><div id="w-node-_7fa422e5-b3ef-6e8e-573c-872c6b5a18d2-e5bcab26" class="styles-pagination"></div><div class="display-none w-embed w-script"><script>
const styleSlides = document.querySelectorAll(".styles-custom-slide");
const stylesPrev = document.querySelector(".styles-button-prev");
const stylesNext = document.querySelector(".styles-button-next");
const stylesPagination = document.querySelector(".styles-pagination");
var currentStyle = Math.floor(styleSlides.length / 2);

// Funkcija za ažuriranje paginacije
function updatePagination() {
  stylesPagination.innerHTML = `
    <span class="label">${currentStyle + 1}</span>
    <svg role="none" width="10" height="14" viewBox="0 0 10 14" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="0.0507812" y="11.9492" width="3.95988" height="1.97994" rx="0.989971" fill="#131D28"/>
      <rect x="2.03125" y="7.98828" width="3.95988" height="1.97994" rx="0.989971" fill="#131D28"/>
      <rect x="4.00977" y="4.03125" width="3.95988" height="1.97994" rx="0.989971" fill="#131D28"/>
      <rect x="5.99023" y="0.0703125" width="3.95988" height="1.97994" rx="0.989971" fill="#131D28"/>
      <rect x="1.04102" y="9.96875" width="3.95988" height="1.97994" rx="0.989971" fill="#131D28"/>
      <rect x="3.02148" y="6.01172" width="3.95988" height="1.97994" rx="0.989971" fill="#131D28"/>
      <rect x="5" y="2.05078" width="3.95988" height="1.97994" rx="0.989971" fill="#131D28"/>
    </svg>
    <span class="label">${styleSlides.length}</span>
  `;
}

// Postavljanje srednjeg slajda kao aktivnog na početku
styleSlides[currentStyle].classList.add("active");
updatePagination();

styleSlides.forEach((slide, index) => {
  slide.addEventListener("click", () => {
    clearInterval(stylesInterval)
    if (document.querySelector(".styles-custom-slide.active") && document.querySelector(".styles-custom-slide.active") !== slide) {
      document.querySelector(".styles-custom-slide.active").classList.remove("active");
    }
    slide.classList.add("active");
    currentStyle = index;
    updatePagination();

    stylesInterval = setInterval(() => {
      currentStyle++;
      if(currentStyle == styleSlides.length) currentStyle = 0
      if (document.querySelector(".styles-custom-slide.active") && document.querySelector(".styles-custom-slide.active") !== styleSlides[currentStyle]) {
        document.querySelector(".styles-custom-slide.active").classList.remove("active");
      }
      styleSlides[currentStyle].classList.add("active");
      updatePagination();
    }, 7000);

  });
});

stylesPrev.addEventListener("click", () => {
  if (currentStyle !== 0) {
    styleSlides[currentStyle - 1].click();
  } else {
    styleSlides[styleSlides.length - 1].click();
  }
});

stylesNext.addEventListener("click", () => {
  if (currentStyle < styleSlides.length - 1) {
    styleSlides[currentStyle + 1].click();
  } else {
    styleSlides[0].click();
  }
});

var stylesInterval = setInterval(() => {
  currentStyle++;
  if(currentStyle == styleSlides.length) currentStyle = 0
  if (document.querySelector(".styles-custom-slide.active") && document.querySelector(".styles-custom-slide.active") !== styleSlides[currentStyle]) {
    document.querySelector(".styles-custom-slide.active").classList.remove("active");
  }
  styleSlides[currentStyle].classList.add("active");
  updatePagination();
}, 7000);

</script></div><div class="display-none w-embed"><style>
  .styles-custom-slide .styles-content {
		opacity: 0;
    transition: opacity 0.3s ease;
    transform: scale(0.9);
  }
	.styles-custom-slide.active .slide-bg {
  	filter: saturate(100%);
    transition: filter 0.3s ease;
  }
  .styles-custom-slide.active .styles-content {
  	opacity: 1;
    transform: scale(1);
  }
</style></div></div></section><section class="section styles-mobile"><div class="container grid"><div id="w-node-_4a3b4713-6c49-7fe5-b4cb-936ca4857375-e5bcab26" class="label-wrapper"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062cffc81f0d2b6e7bdb7_Frame%2018.svg" loading="lazy" alt="" class="label-svg"/><div class="label">styles</div><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062ce1a4d33d9fc250b20_Frame%2019.svg" loading="lazy" alt="" class="label-svg"/></div><h2 id="w-node-b54669d1-edb4-8c50-1525-24d4cfc9e55d-e5bcab26">World of ThreadBeast</h2><p id="w-node-e611c282-02d1-9b4f-985f-96c27fa729eb-e5bcab26" class="paragraph-opacity">Dive into our rotating collection and customize your box starting from one of our style foundations.</p><div id="styles-swiper-mobile" class="swiper styles-mobile w-node-_2fe7e188-96d4-a72a-db91-857960caed6c-e5bcab26"><div class="swiper-wrapper styles-mobile"><div class="swiper-slide styles-mobile"><div class="slide-bg"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67e28d4cd2bf3844d30ff6c4_Rectangle%2023770%20(7).webp" loading="lazy" alt="Stylish man in a brown t-shirt" class="our-style-bg-image"/><div class="slide-overlay"></div></div><div class="styles-mobile-content"><h2 class="text-neutral-white">contemporary</h2><p class="margin-5xl">Contemporary fashion often features minimalist aesthetics, clean lines, and high-quality materials, balancing sophistication with wearability.</p><a href="/styles/contemporary" class="button-link w-inline-block"><div class="button-arrow-wrap"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d00d7bda13bf619651aa6b_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img"/><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d00d7bda13bf619651aa6b_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img-2"/>