b37e5bcaae3/67d062ce1a4d33d9fc250b20_Frame%2019.svg" loading="lazy" alt="" class="label-svg"/></div><h2 class="margin-m">Effortlessly yours</h2><div class="step-1-label-wrapper mobile-hide"><div class="step-separator"></div><div class="label">Step 1</div><div class="step-1-text-content"><h3 class="heading-style-h4 margin-m">SET YOUR PREFERENCES</h3><p class="paragraph-opacity margin-3xl">Take our quick style survey so you only look at what makes you look good.</p></div></div><div class="step-2-label-wrapper mobile-hide"><div class="step-separator"></div><div class="label">Step 2</div><div class="step-2-text-content"><h4 class="margin-m">RATE CLOTHING</h4><p class="paragraph-opacity margin-3xl">Give thumbs up or thumbs down to help refine our understanding of your look.</p></div></div><div class="step-3-label-wrapper mobile-hide"><div class="step-separator"></div><div class="label">Step 3</div><div class="step-3-text-content"><h4 class="margin-m">PREVIEW YOUR BOX</h4><p class="paragraph-opacity margin-3xl">Preview your next delivery, swap out items, and get right to the good stuff.</p><a href="/how-it-works" class="button-link w-inline-block"><div class="button-arrow-wrap"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d07461cc63510c7ba6c73a_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img"/><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d07461cc63510c7ba6c73a_64fb144b87b4be79d2f1a8a4_arrow-blue%20(1)%201.svg" loading="lazy" alt="" class="button-link-img-2"/></div><div class="button-text">how it works</div></a></div></div></div><div id="w-node-_2cb97d91-bac8-81de-b626-40e18653a8a1-8653a869" class="how-it-works-right"><div class="step-1-img-wrapper"></div><div class="step-2-img-wrapper"></div><div class="step-3-img-wrapper"></div></div><div id="w-node-_2cb97d91-bac8-81de-b626-40e18653a8a5-8653a869" class="how-it-works-mobile"><div class="step-1"><div class="step-1-label-wrapper"><div class="step-separator"></div><div class="label">Step 1</div></div><div class="step-1-text-content mobile"><h4 class="step-heading margin-m">SET YOUR PREFERENCES</h4><p class="paragraph-opacity margin-3xl">Take our quick style survey so you only look at what makes you look good.</p></div><div class="step-1-img-wrapper"></div></div><div class="step-2"><div class="step-2-label-wrapper"><div class="step-separator"></div><div class="label">Step 2</div></div><div class="step-2-text-content mobile"><h4 class="step-heading margin-m">RATE CLOTHING</h4><p class="paragraph-opacity margin-3xl">Give thumbs up or thumbs down to help refine our understanding of your look.</p></div><div class="step-2-img-wrapper"></div></div><div class="step-3"><div class="step-3-label-wrapper"><div class="step-separator"></div><div class="label">Step 3</div></div><div class="step-3-text-content mobile"><h4 class="step-heading margin-m">PREVIEW YOUR BOX</h4><p class="paragraph-opacity margin-3xl">Preview your next delivery, swap out items, and get right to the good stuff.</p></div><div class="step-3-img-wrapper"></div></div></div></div></section><section class="section styles"><div class="container grid"><div id="w-node-_3d844c6d-396b-dc88-3768-c9874609456c-e5bcab26" class="styles-heading-wrapper"><div class="label-wrapper"><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062cffc81f0d2b6e7bdb7_Frame%2018.svg" loading="lazy" alt="" class="label-svg"/><div class="label">styles</div><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062ce1a4d33d9fc250b20_Frame%2019.svg" loading="lazy" alt="" class="label-svg"/></div><h2 id="w-node-fd447463-8411-818e-c4d5-7b1cfa71004a-e5bcab26">World of ThreadBeast</h2><p class="paragraph-opacity">Dive into our rotating collection and customize your box starting from one of our style foundations.</p></div><div id="w-node-_278ddefb-3a23-c54c-660b-c413148b3920-e5bcab26" class="styles-arrow-wrapper mobile-hide"><di