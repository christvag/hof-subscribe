	@media only screen and (min-width: 992px) {
    /* Characters */
    .main-button [data-button-animate-chars] {
      overflow: hidden;
      position: relative;
      display: inline-block;
    }

    .main-button [data-button-animate-chars] span {
      display: inline-block;
      position: relative;
      text-shadow: 0px 1.3em currentColor;
      transform: translateY(0em) rotate(0.001deg);
      transition: transform 0.6s cubic-bezier(0.625, 0.05, 0, 1);
    }

    .main-button:hover [data-button-animate-chars] span {
      transform: translateY(-1.3em) rotate(0.001deg);
    }

    /* Background */
    .main-button-bg {
      inset: 0;
      transition: inset 0.6s cubic-bezier(0.625, 0.05, 0, 1);
    }

    .main-button:hover .main-button-bg {
      inset: 0.125em;
    }
  }
</style></div><div class="display-none w-embed w-script"><script>
	function initButtonCharacterStagger() {
  const offsetIncrement = 0.01; // Transition offset increment in seconds
  const buttons = document.querySelectorAll('[data-button-animate-chars]');

  buttons.forEach(button => {
    const text = button.textContent; // Get the button's text content
    button.innerHTML = ''; // Clear the original content

    [...text].forEach((char, index) => {
      const span = document.createElement('span');
      span.textContent = char;
      span.style.transitionDelay = `${index * offsetIncrement}s`;

      // Handle spaces explicitly
      if (char === ' ') {
        span.style.whiteSpace = 'pre'; // Preserve space width
      }

      button.appendChild(span);
    });
  });
}

// Initialize Button Character Stagger Animation
document.addEventListener('DOMContentLoaded', () => {
  initButtonCharacterStagger();
});
</script></div></a></div><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d06749e9fdb6157b6d52a2_Group%2012149.svg" loading="lazy" alt="" class="decor-svg"/><img src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d0674a8c45f79a547c284e_Group%2012148.svg" loading="lazy" alt="" class="decor-svg-right"/></div></div></section></main><main class="main-wrapper home_v2"><section class="section home-hero"><div class="container grid"><div id="w-node-_9b9deefc-90e4-4032-9f31-1d0f4f2322e3-e5bcab26" class="explore-hero-content"><div class="explore-hero-heading"><div class="hero-headline">Change Your Clothes</div><div class="hero-paragraph-2">Subscription Streetwear Boxes</div><a href="/get-started" class="button orange w-button">Get Started</a></div></div></div></section><section class="section bg-neutral-300"><div class="container grid"><div id="w-node-_376642f2-b45a-689b-cee7-771a666b6de5-e5bcab26" class="column-left"><img sizes="100vw" srcset="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/6966c3d6d2d766a7c1ce5911_what-is-tb-left-p-500.jpg 500w, https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/6966c3d6d2d766a7c1ce5911_what-is-tb-left.jpg 533w" alt="" src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/6966c3d6d2d766a7c1ce5911_what-is-tb-left.jpg" loading="lazy" class="home_image_left"/></div><div id="w-node-_9fb874b5-8d0d-0f80-da5c-db0be7030d8d-e5bcab26" class="column-right"><img sizes="100vw" srcset="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/6966c3f6d19f121afe42062b_what-is-tb-right-p-500.jpg 500w, https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/6966c3f6d19f121afe42062b_what-is-tb-right-p-800.jpg 800w, https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/6966c3f6d19f121afe42062b_what-is-tb-right.jpg 842w" alt="" src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/6966c3f6d19f121afe42062b_what-is-tb-right.jpg" loading="lazy" class="home_image_lright"/><div class="label-wrapper"><img loading="lazy" src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062cffc81f0d2b6e7bdb7_Frame%2018.svg" alt="" class="label-svg"/><div class="label">WHAT IS THREADBEAST?</div><img loading="lazy" src="https://cdn.prod.website-files.com/67cfffc29d79bb37e5bcaae3/67d062ce1a4d33d9fc250b20_Frame%2019.svg" alt="" class="label-svg"/></div><div class="text-block-51">Style on Autopilot.</div><div class="text-block-52">Most guys stick to the same three brands. We break the cycle. You share your vibe. We drop a box of premium gear. Hoodies, denim, and tees that actually fit your life. No malls. No guessing.</div><div class="button_wrap"><a href="/explore" class="button-generic w-button">See the Clothes</a></div></div></div></section><section class="section product-carousel bg-neutral-300"><div class="section_header"><div class="text-block-53">New Drops Added Every Week</div><div class="scroll-header"><div class="label-wrapper"><div fs-list-element="items-count" class="item-count">XX</div><div fs-list-element="visible-count-from" class="item-count">Latest</div></div><a href="/explore" class="link-2">See More</a></div></div><div class="collection-list-wrapper-6 w-dyn-list"><div fs-list-element="list" role="list" class="collection-list-3 brand-scroll-list w-dyn-items"><div role="listitem" class="collection-item-3 w-dyn-item"><div class="collection_item_wrapper"><a href="/catalog-products/felt-doraemon-varsity-ojkc058434438" class="w-inline-block"><div class="product_card"><div class="product_image-wrapper"><img loading="lazy" src="https://cdn.prod.website-files.com/67d15482cce61da35752f864/6960502a07838459da0d04f9_PROD000303961_FeltDoraemonVarsityJackets_Blue_front.jpeg" alt="" class="product_image"/><div class="product_rating_badge_wrapper w-condition-invisible"><div class="text-block-33">★ </div><div class="text-block-33">3.8</div><div class="div-block-21"><div class="text-block-33">(</div><div class="text-block-33 review-count-n